{
  "name": "docs",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "docs:dev": "vitepress dev .",
    "docs:build": "vitepress build .",
    "docs:preview": "vitepress preview .",
    "docs:index": "vitepress build . && node scripts/patch-pagefind.mjs && pagefind --site .vitepress/dist --output-path .vitepress/dist/pagefind"
  },
  "devDependencies": {
    "pagefind": "^1.3.0",
    "vitepress": "^1.6.4"
  },
  "dependencies": {
    "@nolebase/vitepress-plugin-git-changelog": "^2.18.2"
  }
}
